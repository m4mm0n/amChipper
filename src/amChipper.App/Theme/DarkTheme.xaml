<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

  <!-- ── Palette ────────────────────────────────────────────────────────────── -->
  <Color x:Key="BgDeepColor">#FF171221</Color>
  <Color x:Key="BgPanelColor">#FF241B32</Color>
  <Color x:Key="BgControlColor">#FF342640</Color>
  <Color x:Key="BgHoverColor">#FF49345B</Color>
  <Color x:Key="BgSelectColor">#FF5F3F78</Color>
  <Color x:Key="AccentColor">#FFB961FF</Color>
  <Color x:Key="AccentLightColor">#FFFFA1F7</Color>
  <Color x:Key="BorderColor">#FF735A8C</Color>
  <Color x:Key="TextPrimaryColor">#FFF9F2FF</Color>
  <Color x:Key="TextSecondaryColor">#FFD5BEDF</Color>
  <Color x:Key="TextDisabledColor">#FF806B8F</Color>
  <Color x:Key="PlayheadColor">#FFFF4444</Color>
  <Color x:Key="GridLineColor">#FF252535</Color>
  <Color x:Key="GridBarColor">#FF303050</Color>

  <SolidColorBrush x:Key="BgDeep"       po:Freeze="False" Color="{StaticResource BgDeepColor}"/>
  <SolidColorBrush x:Key="BgPanel"      po:Freeze="False" Color="{StaticResource BgPanelColor}"/>
  <SolidColorBrush x:Key="BgControl"    po:Freeze="False" Color="{StaticResource BgControlColor}"/>
  <SolidColorBrush x:Key="BgHover"      po:Freeze="False" Color="{StaticResource BgHoverColor}"/>
  <SolidColorBrush x:Key="BgSelect"     po:Freeze="False" Color="{StaticResource BgSelectColor}"/>
  <SolidColorBrush x:Key="Accent"       po:Freeze="False" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="AccentLight"  po:Freeze="False" Color="{StaticResource AccentLightColor}"/>
  <SolidColorBrush x:Key="Border"       po:Freeze="False" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="TextPrimary"  po:Freeze="False" Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondary" po:Freeze="False" Color="{StaticResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="TextDisabled" po:Freeze="False" Color="{StaticResource TextDisabledColor}"/>
  <LinearGradientBrush x:Key="ButtonShine" po:Freeze="False" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#44FFFFFF" Offset="0"/>
    <GradientStop Color="#00FFFFFF" Offset="0.42"/>
    <GradientStop Color="#24000000" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="PanelSheen" po:Freeze="False" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#18FFFFFF" Offset="0"/>
    <GradientStop Color="#00000000" Offset="0.34"/>
    <GradientStop Color="#22000000" Offset="1"/>
  </LinearGradientBrush>
  <DropShadowEffect x:Key="SoftGlow" BlurRadius="12" ShadowDepth="0" Opacity="0.42" Color="#FF5A9BF5"/>
  <DropShadowEffect x:Key="PanelShadow" BlurRadius="18" ShadowDepth="1" Opacity="0.34" Color="#FF000000"/>
  <DropShadowEffect x:Key="NeonGlow" BlurRadius="16" ShadowDepth="0" Opacity="0.58" Color="#FFFF8CFF"/>
  <LinearGradientBrush x:Key="FlStudioChrome" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF41304D" Offset="0"/>
    <GradientStop Color="#FF261B31" Offset="0.52"/>
    <GradientStop Color="#FF15111C" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="FlStudioPanel" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF322542" Offset="0"/>
    <GradientStop Color="#FF211A2D" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="FlStudioStrip" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FF3B2A4E" Offset="0"/>
    <GradientStop Color="#FF231B30" Offset="0.62"/>
    <GradientStop Color="#FF191520" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="FlStudioActive" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFFFA1F7" Offset="0"/>
    <GradientStop Color="#FFB961FF" Offset="0.45"/>
    <GradientStop Color="#FF7447C7" Offset="1"/>
  </LinearGradientBrush>

  <!-- ── Window ─────────────────────────────────────────────────────────────── -->
  <Style TargetType="Window">
    <Setter Property="Background"  Value="{DynamicResource BgDeep}"/>
    <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
    <Setter Property="FontFamily"  Value="Segoe UI"/>
    <Setter Property="FontSize"    Value="12"/>
  </Style>

  <!-- ── TextBlock ─────────────────────────────────────────────────────────── -->
  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="12"/>
  </Style>

  <!-- ── Button ─────────────────────────────────────────────────────────────── -->
  <Style TargetType="Button">
    <Setter Property="Background"         Value="{DynamicResource BgControl}"/>
    <Setter Property="Foreground"         Value="{DynamicResource TextPrimary}"/>
    <Setter Property="BorderBrush"        Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness"    Value="1"/>
    <Setter Property="Padding"            Value="8,3"/>
    <Setter Property="FontFamily"         Value="Segoe UI"/>
    <Setter Property="FontSize"           Value="12"/>
    <Setter Property="FontWeight"         Value="SemiBold"/>
    <Setter Property="Cursor"             Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="{TemplateBinding Padding}">
            <Grid>
              <Border Background="{DynamicResource ButtonShine}" CornerRadius="3" Opacity="0.68"/>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{DynamicResource BgHover}"/>
              <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
              <Setter TargetName="Root" Property="Effect" Value="{DynamicResource SoftGlow}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter Property="Background" Value="{DynamicResource Accent}"/>
              <Setter Property="Foreground" Value="#FFFFFFFF"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource TextDisabled}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── ToggleButton ──────────────────────────────────────────────────────── -->
  <!-- ToggleButton and Button are siblings (both from ButtonBase), so we       -->
  <!-- cannot use BasedOn={x:Type Button} — the template must target ToggleButton -->
  <Style TargetType="ToggleButton">
    <Setter Property="Background"      Value="{DynamicResource BgControl}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="8,3"/>
    <Setter Property="FontFamily"      Value="Segoe UI"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="FontWeight"      Value="SemiBold"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="{TemplateBinding Padding}">
            <Grid>
              <Border Background="{DynamicResource ButtonShine}" CornerRadius="3" Opacity="0.64"/>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{DynamicResource BgHover}"/>
              <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
              <Setter TargetName="Root" Property="Effect" Value="{DynamicResource SoftGlow}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter Property="Background" Value="{DynamicResource Accent}"/>
              <Setter Property="BorderBrush" Value="{DynamicResource AccentLight}"/>
              <Setter TargetName="Root" Property="Effect" Value="{DynamicResource SoftGlow}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter Property="Background" Value="{DynamicResource BgSelect}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource TextDisabled}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── TextBox ────────────────────────────────────────────────────────────── -->
  <Style TargetType="TextBox">
    <Setter Property="Background"      Value="{DynamicResource BgControl}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="4,2"/>
    <Setter Property="CaretBrush"      Value="{DynamicResource Accent}"/>
    <Setter Property="SelectionBrush"  Value="{DynamicResource Accent}"/>
    <Setter Property="FontFamily"      Value="Consolas"/>
    <Setter Property="FontSize"        Value="12"/>
  </Style>

  <Style TargetType="ProgressBar">
    <Setter Property="Background" Value="#FF17131F"/>
    <Setter Property="Foreground" Value="{DynamicResource AccentLight}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Height" Value="8"/>
  </Style>

  <!-- ── Slider ────────────────────────────────────────────────────────────── -->
  <Style x:Key="ThemedSliderThumb" TargetType="Thumb">
    <Setter Property="Width" Value="16"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Background" Value="{DynamicResource FlStudioActive}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource AccentLight}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Effect" Value="{DynamicResource SoftGlow}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border x:Name="ThumbRoot"
                  CornerRadius="3"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Background="{TemplateBinding Background}">
            <Grid>
              <Border Background="{DynamicResource ButtonShine}" CornerRadius="2" Opacity="0.7"/>
              <Rectangle Width="2"
                         Fill="{DynamicResource TextPrimary}"
                         Opacity="0.65"
                         HorizontalAlignment="Center"
                         Margin="0,3"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="ThumbRoot" Property="BorderBrush" Value="{DynamicResource TextPrimary}"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
              <Setter TargetName="ThumbRoot" Property="Background" Value="{DynamicResource AccentLight}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SliderTrackButton" TargetType="RepeatButton">
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Border Height="6"
                  CornerRadius="3"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{DynamicResource Border}"
                  BorderThickness="1"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="Slider">
    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
    <Setter Property="Background" Value="{DynamicResource BgControl}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
    <Setter Property="MinHeight" Value="22"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid x:Name="Root" Margin="2,0">
            <Track x:Name="PART_Track" VerticalAlignment="Center">
              <Track.DecreaseRepeatButton>
                <RepeatButton Style="{StaticResource SliderTrackButton}"
                              Background="{DynamicResource FlStudioActive}"
                              Command="Slider.DecreaseLarge"/>
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb Style="{StaticResource ThemedSliderThumb}"/>
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Style="{StaticResource SliderTrackButton}"
                              Background="{DynamicResource BgControl}"
                              Command="Slider.IncreaseLarge"/>
              </Track.IncreaseRepeatButton>
            </Track>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
              <Setter TargetName="Root" Property="LayoutTransform">
                <Setter.Value>
                  <RotateTransform Angle="-90"/>
                </Setter.Value>
              </Setter>
              <Setter Property="MinWidth" Value="22"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── ComboBox ─────────────────────────────────────────────────────────────
       Full ControlTemplate so the popup dropdown also uses dark colours.        -->
  <ControlTemplate x:Key="ComboBoxToggleButtonTemplate" TargetType="ToggleButton">
    <Border x:Name="Root"
            Background="{DynamicResource BgControl}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="1"
            CornerRadius="3">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition/>
          <ColumnDefinition Width="18"/>
        </Grid.ColumnDefinitions>
        <!-- Arrow -->
        <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
              Fill="{DynamicResource TextSecondary}"
              Data="M 0 0 L 4 4 L 8 0 Z"/>
      </Grid>
    </Border>
    <ControlTemplate.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Accent}"/>
        <Setter TargetName="Root" Property="Background"  Value="{DynamicResource BgHover}"/>
      </Trigger>
      <Trigger Property="IsChecked" Value="True">
        <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Accent}"/>
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style TargetType="ComboBox">
    <Setter Property="Background"         Value="{DynamicResource BgControl}"/>
    <Setter Property="Foreground"         Value="{DynamicResource TextPrimary}"/>
    <Setter Property="BorderBrush"        Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness"    Value="1"/>
    <Setter Property="Padding"            Value="6,3"/>
    <Setter Property="FontFamily"         Value="Segoe UI"/>
    <Setter Property="FontSize"           Value="12"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <!-- Toggle button covers the whole control -->
            <ToggleButton x:Name="ToggleButton"
                          Template="{StaticResource ComboBoxToggleButtonTemplate}"
                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                          ClickMode="Press"/>
            <!-- Selected-item text, inset so it doesn't overlap the arrow -->
            <ContentPresenter x:Name="ContentSite"
                              IsHitTestVisible="False"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                              Margin="6,3,22,3"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              TextElement.Foreground="{DynamicResource TextPrimary}"/>
            <!-- Editable text box (only used when IsEditable=True) -->
            <TextBox x:Name="PART_EditableTextBox"
                     Visibility="Hidden"
                     IsReadOnly="{TemplateBinding IsReadOnly}"
                     Margin="6,3,22,3"
                     Focusable="True"
                     Background="Transparent"
                     Foreground="{DynamicResource TextPrimary}"
                     BorderThickness="0"/>
            <!-- Drop-down popup -->
            <Popup x:Name="Popup"
                   Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True"
                   Focusable="False"
                   PopupAnimation="Slide">
              <Grid x:Name="DropDown"
                    SnapsToDevicePixels="True"
                    MinWidth="{TemplateBinding ActualWidth}"
                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                <Border x:Name="DropDownBorder"
                        Background="{DynamicResource BgControl}"
                        BorderBrush="{DynamicResource Accent}"
                        BorderThickness="1"
                        CornerRadius="0,0,3,3"
                        Effect="{DynamicResource PanelShadow}">
                  <ScrollViewer SnapsToDevicePixels="True">
                    <StackPanel IsItemsHost="True"
                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                  </ScrollViewer>
                </Border>
              </Grid>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEditable" Value="True">
              <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
              <Setter TargetName="ContentSite"          Property="Visibility" Value="Hidden"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource TextDisabled}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ComboBoxItem must also be explicitly dark-themed; otherwise the popup    -->
  <!-- items inherit system highlight colours (dark text on light background).  -->
  <Style TargetType="ComboBoxItem">
    <Setter Property="Foreground"         Value="{DynamicResource TextPrimary}"/>
    <Setter Property="Background"         Value="Transparent"/>
    <Setter Property="Padding"            Value="8,4"/>
    <Setter Property="FontFamily"         Value="Segoe UI"/>
    <Setter Property="FontSize"           Value="12"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter TextElement.Foreground="{DynamicResource TextPrimary}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource BgHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource BgSelect}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Accent}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource TextDisabled}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── ListBox ────────────────────────────────────────────────────────────── -->
  <Style TargetType="ListBox">
    <Setter Property="Background"      Value="{DynamicResource BgPanel}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
  </Style>

  <Style TargetType="ListBoxItem">
    <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
    <Setter Property="Padding"     Value="6,3"/>
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border Background="{TemplateBinding Background}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{DynamicResource BgHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="{DynamicResource BgSelect}"/>
              <Setter Property="Foreground" Value="{DynamicResource AccentLight}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── CheckBox ───────────────────────────────────────────────────────────── -->
  <Style TargetType="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Margin" Value="0,2"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Grid Background="Transparent">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="18"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Box"
                    Width="13" Height="13"
                    VerticalAlignment="Center"
                    Background="{DynamicResource BgControl}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="1"
                    CornerRadius="2">
              <Grid>
                <Border Background="{DynamicResource ButtonShine}" CornerRadius="2" Opacity="0.46"/>
                <Path x:Name="Check"
                      Visibility="Collapsed"
                      Stroke="{DynamicResource TextPrimary}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 2 6 L 5 9 L 11 2"/>
              </Grid>
            </Border>
            <ContentPresenter Grid.Column="1"
                              Margin="5,0,0,0"
                              VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentLight}"/>
              <Setter TargetName="Box" Property="Effect" Value="{DynamicResource SoftGlow}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Box" Property="Background" Value="{DynamicResource Accent}"/>
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentLight}"/>
              <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource TextDisabled}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── GridSplitter ──────────────────────────────────────────────────────── -->
  <Style TargetType="GridSplitter">
    <Setter Property="Background" Value="{DynamicResource Border}"/>
  </Style>

  <!-- ── ScrollBar ─────────────────────────────────────────────────────────── -->
  <Style x:Key="ThemedScrollBarButton" TargetType="RepeatButton">
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="Background" Value="{DynamicResource BgControl}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ThemedScrollBarThumb" TargetType="Thumb">
    <Setter Property="Background" Value="{DynamicResource FlStudioActive}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource AccentLight}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border CornerRadius="2"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="{DynamicResource BgControl}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
    <Setter Property="Width" Value="18"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid x:Name="Root" Background="{TemplateBinding Background}">
            <Grid.RowDefinitions>
              <RowDefinition Height="18"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="18"/>
            </Grid.RowDefinitions>
            <RepeatButton Grid.Row="0"
                          Style="{StaticResource ThemedScrollBarButton}"
                          Command="ScrollBar.LineUpCommand"
                          Content="▲"/>
            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
              <Track.DecreaseRepeatButton>
                <RepeatButton Style="{StaticResource ThemedScrollBarButton}" Command="ScrollBar.PageUpCommand"/>
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb Style="{StaticResource ThemedScrollBarThumb}"/>
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Style="{StaticResource ThemedScrollBarButton}" Command="ScrollBar.PageDownCommand"/>
              </Track.IncreaseRepeatButton>
            </Track>
            <RepeatButton Grid.Row="2"
                          Style="{StaticResource ThemedScrollBarButton}"
                          Command="ScrollBar.LineDownCommand"
                          Content="▼"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
              <Setter Property="Height" Value="18"/>
              <Setter Property="Width" Value="Auto"/>
              <Setter TargetName="Root" Property="LayoutTransform">
                <Setter.Value>
                  <RotateTransform Angle="-90"/>
                </Setter.Value>
              </Setter>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── Menu ──────────────────────────────────────────────────────────────── -->
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF263864"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFF4F7FF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF0D111C"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFF4F7FF"/>

  <Style TargetType="Menu">
    <Setter Property="Background" Value="{DynamicResource FlStudioChrome}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="13"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    <Setter Property="Background" Value="{DynamicResource BgDeep}"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="MinHeight" Value="30"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="MenuItem">
          <Grid SnapsToDevicePixels="True">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition x:Name="IconColumn" Width="28"/>
                  <ColumnDefinition x:Name="HeaderColumn" Width="Auto"/>
                  <ColumnDefinition x:Name="GestureColumn" Width="96"/>
                  <ColumnDefinition x:Name="ArrowColumn" Width="16"/>
                </Grid.ColumnDefinitions>

                <ContentPresenter x:Name="IconHost"
                                  Grid.Column="0"
                                  ContentSource="Icon"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                <ContentPresenter x:Name="HeaderHost"
                                  Grid.Column="1"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center"
                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                <TextBlock x:Name="GestureHost"
                           Grid.Column="2"
                           Text="{TemplateBinding InputGestureText}"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="14,0,8,0"/>
                <Path x:Name="SubmenuArrow"
                      Grid.Column="3"
                      Data="M 0 0 L 5 4 L 0 8 Z"
                      Fill="{DynamicResource TextSecondary}"
                      Width="5"
                      Height="8"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
              </Grid>
            </Border>

            <Popup x:Name="PART_Popup"
                   AllowsTransparency="True"
                   Focusable="False"
                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                   Placement="Right"
                   PopupAnimation="Fade">
              <Border Background="{DynamicResource FlStudioChrome}"
                      BorderBrush="{DynamicResource Accent}"
                      BorderThickness="1"
                      MinWidth="250">
                <Border.Effect>
                  <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.42" Color="#FF000000"/>
                </Border.Effect>
                <StackPanel IsItemsHost="True"
                            KeyboardNavigation.DirectionalNavigation="Cycle"/>
              </Border>
            </Popup>
          </Grid>

          <ControlTemplate.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
              <Setter TargetName="Root" Property="Padding" Value="12,7"/>
              <Setter TargetName="Root" Property="Background" Value="Transparent"/>
              <Setter TargetName="IconColumn" Property="Width" Value="0"/>
              <Setter TargetName="GestureColumn" Property="Width" Value="0"/>
              <Setter TargetName="ArrowColumn" Property="Width" Value="0"/>
              <Setter TargetName="GestureHost" Property="Visibility" Value="Collapsed"/>
              <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed"/>
              <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
              <Setter TargetName="IconColumn" Property="Width" Value="0"/>
              <Setter TargetName="GestureColumn" Property="Width" Value="0"/>
              <Setter TargetName="ArrowColumn" Property="Width" Value="0"/>
              <Setter TargetName="GestureHost" Property="Visibility" Value="Collapsed"/>
              <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
              <Setter TargetName="HeaderColumn" Property="Width" Value="*"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuItem">
              <Setter TargetName="HeaderColumn" Property="Width" Value="*"/>
              <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource BgHover}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentLight}"/>
              <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource BgSelect}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Accent}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource TextDisabled}"/>
              <Setter TargetName="GestureHost" Property="Foreground" Value="{DynamicResource TextDisabled}"/>
              <Setter TargetName="SubmenuArrow" Property="Fill" Value="{DynamicResource TextDisabled}"/>
              <Setter TargetName="Root" Property="Opacity" Value="0.62"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="Separator">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Separator">
          <Border Height="1" Margin="8,4" Background="{DynamicResource Border}"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── TabControl ─────────────────────────────────────────────────────────── -->
  <Style TargetType="TabControl">
    <Setter Property="Background"      Value="{DynamicResource FlStudioPanel}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <Style TargetType="ToolTip">
    <Setter Property="Background" Value="{DynamicResource BgControl}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <Style TargetType="TabItem">
    <Setter Property="Background"      Value="{DynamicResource BgControl}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextSecondary}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource Border}"/>
    <Setter Property="Padding"         Value="15,7"/>
    <Setter Property="FontWeight"      Value="SemiBold"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="Root" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="1,1,1,0" CornerRadius="5,5,0,0"
                  Margin="2,0" Padding="{TemplateBinding Padding}">
            <Grid>
              <Border x:Name="TabShine" Background="{DynamicResource ButtonShine}" CornerRadius="4,4,0,0" Opacity="0.28"/>
              <Border x:Name="AccentLine" Height="3" VerticalAlignment="Bottom" CornerRadius="2"
                      Background="{DynamicResource AccentLight}" Opacity="0"/>
              <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource FlStudioPanel}"/>
              <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Accent}"/>
              <Setter TargetName="TabShine" Property="Opacity" Value="0.22"/>
              <Setter TargetName="AccentLine" Property="Opacity" Value="0.88"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource BgHover}"/>
              <Setter TargetName="TabShine" Property="Opacity" Value="0.18"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── StatusBar ─────────────────────────────────────────────────────────── -->
  <Style TargetType="StatusBar">
    <Setter Property="Background" Value="{DynamicResource FlStudioChrome}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
    <Setter Property="FontFamily" Value="Consolas"/>
    <Setter Property="FontSize"   Value="11"/>
  </Style>

  <!-- ── Settings / grouped editor panels ──────────────────────────────────── -->
  <Style x:Key="SettingsPanel" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource FlStudioStrip}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="7"/>
    <Setter Property="Padding" Value="12"/>
    <Setter Property="Margin" Value="0,0,0,10"/>
    <Setter Property="Effect" Value="{DynamicResource PanelShadow}"/>
  </Style>

  <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
    <Setter Property="Foreground" Value="{DynamicResource AccentLight}"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Margin" Value="0,0,0,8"/>
  </Style>

  <Style x:Key="SettingLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Margin" Value="0,0,10,0"/>
  </Style>

  <Style x:Key="FlPanel" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource FlStudioPanel}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Effect" Value="{DynamicResource PanelShadow}"/>
  </Style>

  <Style x:Key="FlMixerStrip" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource FlStudioStrip}"/>
    <Setter Property="BorderBrush" Value="#FF59436C"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Effect" Value="{DynamicResource PanelShadow}"/>
  </Style>

</ResourceDictionary>
