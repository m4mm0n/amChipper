<Window x:Class="amChipper.App.Views.NewSongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding [NewTrack]}"
        Width="520"
        Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDeep}">
  <Border Margin="18"
          Padding="18"
          Background="{DynamicResource BgPanel}"
          BorderBrush="{DynamicResource Border}"
          BorderThickness="1"
          CornerRadius="6">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="0,0,0,16">
        <TextBlock Text="{Binding [NewTrackSetup]}"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}"/>
        <TextBlock Text="{Binding [NewTrackIntro]}"
                   Margin="0,4,0,0"
                   Foreground="{DynamicResource TextSecondary}"/>
      </StackPanel>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="42"/>
          <RowDefinition Height="42"/>
          <RowDefinition Height="42"/>
          <RowDefinition Height="42"/>
          <RowDefinition Height="42"/>
          <RowDefinition Height="42"/>
          <RowDefinition Height="42"/>
          <RowDefinition Height="42"/>
          <RowDefinition Height="42"/>
          <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [Title]}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
        <TextBox x:Name="TitleBox" Grid.Row="0" Grid.Column="1" Text="{Binding [NewSongDefaultTitle]}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [ProjectFormat]}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
        <ComboBox x:Name="FormatBox" Grid.Row="1" Grid.Column="1" SelectedIndex="0">
          <ComboBoxItem Content="{Binding DataContext[AmChipperNativeChip], RelativeSource={RelativeSource AncestorType=Window}}" Tag="AmChip"/>
          <ComboBoxItem Content="ProTracker MOD" Tag="MOD"/>
          <ComboBoxItem Content="FastTracker XM" Tag="XM"/>
          <ComboBoxItem Content="Impulse Tracker IT" Tag="IT"/>
          <ComboBoxItem Content="Scream Tracker S3M" Tag="S3M"/>
          <ComboBoxItem Content="OpenMPT MPTM" Tag="OpenMpt"/>
        </ComboBox>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding [ChannelsMixerLanes]}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
        <TextBox x:Name="ChannelsBox" Grid.Row="2" Grid.Column="1" Text="8"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding [Patterns]}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
        <TextBox x:Name="PatternsBox" Grid.Row="3" Grid.Column="1" Text="4"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding [RowsPerPattern]}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
        <TextBox x:Name="RowsBox" Grid.Row="4" Grid.Column="1" Text="64"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding [RowsPerBeat]}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
        <TextBox x:Name="RowsPerBeatBox" Grid.Row="5" Grid.Column="1" Text="4"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding [BpmShort]}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
        <TextBox x:Name="BpmBox" Grid.Row="6" Grid.Column="1" Text="125"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="{Binding [TrackerSpeed]}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
        <TextBox x:Name="SpeedBox" Grid.Row="7" Grid.Column="1" Text="6"/>

        <CheckBox x:Name="SamplesBox" Grid.Row="8" Grid.Column="1" Content="{Binding [IncludeDefaultChipSamples]}" IsChecked="True"/>
        <CheckBox x:Name="BlocksBox" Grid.Row="9" Grid.Column="1" Content="{Binding [CreatePlaylistBlocks]}" IsChecked="True"/>
      </Grid>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
        <Button Content="{Binding [Cancel]}" Width="92" Margin="0,0,8,0" IsCancel="True"/>
        <Button Content="{Binding [Create]}" Width="110" IsDefault="True" Click="Create_Click"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
