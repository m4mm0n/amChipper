<Window x:Class="amChipper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:amChipper.App.ViewModels"
        xmlns:transport="clr-namespace:amChipper.App.Controls.Transport"
        xmlns:browser="clr-namespace:amChipper.App.Controls.InstrumentBrowser"
        xmlns:channelRack="clr-namespace:amChipper.App.Controls.ChannelRack"
        xmlns:automation="clr-namespace:amChipper.App.Controls.Automation"
        xmlns:piano="clr-namespace:amChipper.App.Controls.PianoRoll"
        xmlns:song="clr-namespace:amChipper.App.Controls.SongEditor"
        xmlns:pattern="clr-namespace:amChipper.App.Controls.PatternEditor"
        Title="{Binding Title}"
        Width="1400" Height="860"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/icon_clean.png"
        Background="{DynamicResource BgDeep}"
        ToolTipService.InitialShowDelay="{Binding ToolTipInitialDelayMs}"
        ToolTipService.ShowDuration="{Binding ToolTipDurationMs}">

  <Window.InputBindings>
    <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
    <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
    <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveFileCommand}"/>
    <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}"/>
    <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewSongCommand}"/>
    <KeyBinding Key="Space" Command="{Binding TogglePlaybackCommand}"/>
    <KeyBinding Key="Space" Modifiers="Shift" Command="{Binding StopCommand}"/>
    <KeyBinding Key="D1" Modifiers="Control" Command="{Binding SetPlaybackScopeCommand}" CommandParameter="Song"/>
    <KeyBinding Key="D2" Modifiers="Control" Command="{Binding SetPlaybackScopeCommand}" CommandParameter="Pattern"/>
    <KeyBinding Key="D3" Modifiers="Control" Command="{Binding SetPlaybackScopeCommand}" CommandParameter="PianoRoll"/>
    <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}"/>
  </Window.InputBindings>

  <!-- ── Top-level layout ──────────────────────────────────────────────────── -->
  <DockPanel>

    <!-- Menu bar -->
    <Menu DockPanel.Dock="Top" Padding="4,2" Background="{DynamicResource FlStudioChrome}">
      <MenuItem Header="{Binding [MenuFile]}">
        <MenuItem Header="{Binding [NewSong]}"    Command="{Binding NewSongCommand}"  InputGestureText="Ctrl+N">
          <MenuItem.Icon><TextBlock Text="+" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [Open]}"       Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O">
          <MenuItem.Icon><TextBlock Text="⌕" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [Save]}"        Command="{Binding SaveFileCommand}" InputGestureText="Ctrl+S">
          <MenuItem.Icon><TextBlock Text="▣" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [SaveAs]}"    Command="{Binding SaveAsCommand}"   InputGestureText="Ctrl+Shift+S">
          <MenuItem.Icon><TextBlock Text="▤" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [ExportTo]}" Command="{Binding ExportToCommand}">
          <MenuItem.Icon><TextBlock Text="⇱" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [ImportMidi]}" Command="{Binding ImportPianoRollMidiCommand}">
          <MenuItem.Icon><TextBlock Text="♪" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [ImportFsc]}" Command="{Binding ImportPianoRollFscCommand}">
          <MenuItem.Icon><TextBlock Text="♬" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [Exit]}" Click="MenuItem_Exit">
          <MenuItem.Icon><TextBlock Text="×" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="{Binding [MenuEdit]}">
        <MenuItem Header="{Binding [Undo]}"  Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z">
          <MenuItem.Icon><TextBlock Text="↶" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [Redo]}"  Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y">
          <MenuItem.Icon><TextBlock Text="↷" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [Cut]}"   InputGestureText="Ctrl+X">
          <MenuItem.Icon><TextBlock Text="✂" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [Copy]}"  InputGestureText="Ctrl+C">
          <MenuItem.Icon><TextBlock Text="⧉" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [Paste]}" InputGestureText="Ctrl+V">
          <MenuItem.Icon><TextBlock Text="▣" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="{Binding [MenuSong]}">
        <MenuItem Header="{Binding [PlayPause]}" Command="{Binding TogglePlaybackCommand}" InputGestureText="Space">
          <MenuItem.Icon><TextBlock Text="▶" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [Stop]}" Command="{Binding StopCommand}" InputGestureText="Shift+Space">
          <MenuItem.Icon><TextBlock Text="■" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [PlaySongScope]}" Command="{Binding SetPlaybackScopeCommand}" CommandParameter="Song" InputGestureText="Ctrl+1">
          <MenuItem.Icon><TextBlock Text="▦" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [PlayPatternScope]}" Command="{Binding SetPlaybackScopeCommand}" CommandParameter="Pattern" InputGestureText="Ctrl+2">
          <MenuItem.Icon><TextBlock Text="▥" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [PlayPianoRollScope]}" Command="{Binding SetPlaybackScopeCommand}" CommandParameter="PianoRoll" InputGestureText="Ctrl+3">
          <MenuItem.Icon><TextBlock Text="▤" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [AddTrack]}"   Command="{Binding AddTrackCommand}">
          <MenuItem.Icon><TextBlock Text="+T" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [AddPattern]}" Command="{Binding AddPatternCommand}">
          <MenuItem.Icon><TextBlock Text="+P" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [AddInstrument]}" Command="{Binding AddInstrumentCommand}">
          <MenuItem.Icon><TextBlock Text="+I" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [DuplicateBlock]}" Command="{Binding SongEditor.DuplicateBlockCommand}" InputGestureText="Ctrl+D">
          <MenuItem.Icon><TextBlock Text="⧉" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [DuplicatePattern]}" Command="{Binding PatternEditor.DuplicatePatternCommand}" InputGestureText="Ctrl+D">
          <MenuItem.Icon><TextBlock Text="⧉" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="{Binding [MenuView]}">
        <MenuItem Header="{Binding [TabProjectHub]}"   Click="View_ProjectHub">
          <MenuItem.Icon><TextBlock Text="⌂" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [TabSongEditor]}"    Click="View_SongEditor">
          <MenuItem.Icon><TextBlock Text="▦" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [TabAnalyzer]}" Click="View_Analyzer">
          <MenuItem.Icon><TextBlock Text="▥" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [TabPianoRoll]}"     Click="View_PianoRoll">
          <MenuItem.Icon><TextBlock Text="▤" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [TabPatternEditor]}" Click="View_PatternEditor">
          <MenuItem.Icon><TextBlock Text="#" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [Theme]}">
          <MenuItem Header="FL Grape"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="FL Grape"/>
          <MenuItem Header="Neon Studio"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Neon"/>
          <MenuItem Header="Classic Tracker"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Classic"/>
          <MenuItem Header="Amber CRT"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Amber"/>
          <MenuItem Header="Midnight Pro"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Midnight Pro"/>
          <MenuItem Header="Ice Matrix"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Ice Matrix"/>
          <MenuItem Header="Magenta Circuit"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Magenta Circuit"/>
          <MenuItem Header="Carbon Lime"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Carbon Lime"/>
          <MenuItem Header="Ruby Wave"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Ruby Wave"/>
          <MenuItem Header="Ocean Lab"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Ocean Lab"/>
          <MenuItem Header="Steel Mono"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Steel Mono"/>
          <MenuItem Header="Sunset Pop"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Sunset Pop"/>
          <MenuItem Header="Cyber Cyan"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Cyber Cyan"/>
          <MenuItem Header="Toxic Acid"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Toxic Acid"/>
          <MenuItem Header="Royal Neon"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Royal Neon"/>
          <MenuItem Header="Graphite Gold"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Graphite Gold"/>
          <MenuItem Header="Circuit Blue"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Circuit Blue"/>
          <MenuItem Header="Laser Orange"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Laser Orange"/>
          <MenuItem Header="Vapor Glass"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Vapor Glass"/>
          <MenuItem Header="Terminal Green"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Terminal Green"/>
          <MenuItem Header="Hotline Pink"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Hotline Pink"/>
          <MenuItem Header="Arctic Steel"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Arctic Steel"/>
          <MenuItem Header="Copper Desk"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Copper Desk"/>
          <MenuItem Header="Deep Red"
                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Deep Red"/>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="{Binding [MenuHelp]}">
        <MenuItem Header="{Binding [FeatureReference]}" Command="{Binding ShowHelpCommand}" InputGestureText="F1">
          <MenuItem.Icon><TextBlock Text="?" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{Binding [TipOfTheDay]}" Command="{Binding ShowTipCommand}">
          <MenuItem.Icon><TextBlock Text="!" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
        <Separator/>
        <MenuItem Header="{Binding [About]}" Command="{Binding ShowAboutCommand}">
          <MenuItem.Icon><TextBlock Text="i" FontWeight="Bold"/></MenuItem.Icon>
        </MenuItem>
      </MenuItem>
    </Menu>

    <!-- Transport bar -->
    <transport:TransportBar DockPanel.Dock="Top"
                            DataContext="{Binding}"
                            Margin="0,0,0,1"/>

    <!-- Status bar -->
    <StatusBar DockPanel.Dock="Bottom" Height="24">
      <StatusBarItem>
        <TextBlock Text="{Binding StatusText}"/>
      </StatusBarItem>
      <Separator/>
      <StatusBarItem HorizontalAlignment="Right">
        <TextBlock>
          <Run Text="{Binding [BpmLabel]}"/><Run Text="{Binding Bpm}"/>
          <Run Text="{Binding [RowsPerBeatLabel]}"/><Run Text="{Binding RowsPerBeat}"/>
        </TextBlock>
      </StatusBarItem>
    </StatusBar>

    <!-- Main content area -->
    <Grid Background="{DynamicResource BgDeep}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="LeftPanelColumn" Width="200" MinWidth="140" MaxWidth="320"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left panel: Instrument browser -->
      <browser:InstrumentBrowserControl Grid.Column="0"
                                        DataContext="{Binding InstrumentBrowser}"/>

      <GridSplitter Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    DragCompleted="MainSplitter_DragCompleted"/>

      <!-- Right panel: tabbed editors -->
      <TabControl Grid.Column="2" x:Name="MainTabControl"
                  Background="{DynamicResource FlStudioPanel}"
                  BorderThickness="0"
                  Padding="6,4,6,0"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="MainTabControl_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="MainTabControl_PreviewMouseMove"
                  DragOver="MainTabControl_DragOver"
                  Drop="MainTabControl_Drop">

        <TabItem x:Name="ProjectHubTab" Header="{Binding [TabProjectHub]}" Tag="⌂">
          <ScrollViewer Background="{DynamicResource BgDeep}"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="18">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="0.85*"/>
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <Border Style="{StaticResource SettingsPanel}" Padding="18" Margin="0,0,0,12">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                      <TextBlock Text="{Binding [SongTitle]}" Style="{StaticResource SettingLabel}"/>
                      <TextBox Text="{Binding ProjectTitleEdit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentLight}"
                               Padding="8,4"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                      <TextBlock Text="{Binding [Artist]}" Style="{StaticResource SettingLabel}"/>
                      <TextBox Text="{Binding ProjectArtistEdit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                               Padding="8,4"/>
                    </StackPanel>
                    <UniformGrid Grid.Row="2" Columns="2" Margin="0,16,0,0">
                      <Border Style="{StaticResource FlPanel}" Padding="12" Margin="0,0,8,8">
                        <StackPanel>
                          <TextBlock Text="{Binding [ProjectFormat]}" Style="{StaticResource SettingLabel}"/>
                          <TextBlock Text="{Binding ProjectFormatLabel}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" TextWrapping="Wrap"/>
                        </StackPanel>
                      </Border>
                      <Border Style="{StaticResource FlPanel}" Padding="12" Margin="8,0,0,8">
                        <StackPanel>
                          <TextBlock Text="{Binding [ProjectTiming]}" Style="{StaticResource SettingLabel}"/>
                          <TextBlock Text="{Binding ProjectTimingLabel}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" TextWrapping="Wrap"/>
                        </StackPanel>
                      </Border>
                      <Border Style="{StaticResource FlPanel}" Padding="12" Margin="0,8,8,0">
                        <StackPanel>
                          <TextBlock Text="{Binding [ProjectStructure]}" Style="{StaticResource SettingLabel}"/>
                          <TextBlock Text="{Binding ProjectStatsLabel}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" TextWrapping="Wrap"/>
                        </StackPanel>
                      </Border>
                      <Border Style="{StaticResource FlPanel}" Padding="12" Margin="8,8,0,0">
                        <StackPanel>
                          <TextBlock Text="{Binding [ProjectRestart]}" Style="{StaticResource SettingLabel}"/>
                          <TextBlock Text="{Binding ProjectRestartLabel}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" TextWrapping="Wrap"/>
                        </StackPanel>
                      </Border>
                    </UniformGrid>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsPanel}" Padding="16" Margin="0,0,0,12">
                  <StackPanel>
                    <TextBlock Text="{Binding [QuickActions]}" Style="{StaticResource SectionTitle}"/>
                    <UniformGrid Columns="4">
                      <Button Content="{Binding [Open], StringFormat=⌕ {0}}" Command="{Binding OpenFileCommand}" Margin="0,0,8,8" MinHeight="36"
                              ToolTip="{Binding [TipHubOpen]}"/>
                      <Button Content="{Binding [Save], StringFormat=▣ {0}}" Command="{Binding SaveFileCommand}" Margin="0,0,8,8" MinHeight="36"
                              ToolTip="{Binding [TipHubSave]}"/>
                      <Button Content="{Binding [ExportTo], StringFormat=⇱ {0}}" Command="{Binding ExportToCommand}" Margin="0,0,8,8" MinHeight="36"
                              ToolTip="{Binding [TipHubExport]}"/>
                      <Button Content="{Binding [PlayPause], StringFormat=▶ {0}}" Command="{Binding TogglePlaybackCommand}" Margin="0,0,0,8" MinHeight="36"
                              ToolTip="{Binding [TipHubPlay]}"/>
                      <Button Content="{Binding [NewSong], StringFormat=+ {0}}" Command="{Binding NewSongCommand}" Margin="0,0,8,8" MinHeight="36"/>
                      <Button Content="{Binding [AddTrack], StringFormat=+T {0}}" Command="{Binding AddTrackCommand}" Margin="0,0,8,8" MinHeight="36"/>
                      <Button Content="{Binding [AddPattern], StringFormat=+P {0}}" Command="{Binding AddPatternCommand}" Margin="0,0,8,8" MinHeight="36"/>
                      <Button Content="{Binding [AddInstrument], StringFormat=+I {0}}" Command="{Binding AddInstrumentCommand}" Margin="0,0,0,8" MinHeight="36"/>
                      <Button Content="{Binding [TabSongEditor], StringFormat=▦ {0}}" Click="View_SongEditor" Margin="0,0,8,0" MinHeight="34"/>
                      <Button Content="{Binding [TabPianoRoll], StringFormat=▤ {0}}" Click="View_PianoRoll" Margin="0,0,8,0" MinHeight="34"/>
                      <Button Content="{Binding [TabPatternEditor], StringFormat=# {0}}" Click="View_PatternEditor" Margin="0,0,8,0" MinHeight="34"/>
                      <Button Content="{Binding [FeatureReference], StringFormat=? {0}}" Command="{Binding ShowHelpCommand}" Margin="0" MinHeight="34"/>
                    </UniformGrid>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}" Padding="16">
                  <StackPanel>
                    <TextBlock Text="{Binding [ProjectState]}" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="{Binding ProjectSourceLabel}" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ProjectDirtyLabel}" Foreground="{DynamicResource AccentLight}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ProjectPlaybackLabel}" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ProjectExportLabel}" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </StackPanel>

              <StackPanel Grid.Column="2">
                <Border Style="{StaticResource SettingsPanel}" Padding="16" Margin="0,0,0,12">
                  <StackPanel>
                    <TextBlock Text="{Binding [Workflow]}" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,4,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="01" Foreground="{DynamicResource AccentLight}" FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
                      <TextBlock Grid.Column="1" Text="{Binding [WorkflowLoad]}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                      <TextBlock Grid.Column="2" Text="{Binding WorkflowLoadState}" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                    <Separator Margin="0,9"/>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="02" Foreground="{DynamicResource AccentLight}" FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
                      <TextBlock Grid.Column="1" Text="{Binding [WorkflowEdit]}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                      <TextBlock Grid.Column="2" Text="{Binding WorkflowEditState}" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                    <Separator Margin="0,9"/>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="03" Foreground="{DynamicResource AccentLight}" FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
                      <TextBlock Grid.Column="1" Text="{Binding [WorkflowPreview]}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                      <TextBlock Grid.Column="2" Text="{Binding WorkflowPreviewState}" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                    <Separator Margin="0,9"/>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="04" Foreground="{DynamicResource AccentLight}" FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
                      <TextBlock Grid.Column="1" Text="{Binding [WorkflowExport]}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                      <TextBlock Grid.Column="2" Text="{Binding WorkflowExportState}" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}" Padding="16" Margin="0,0,0,12">
                  <StackPanel>
                    <TextBlock Text="{Binding [SessionTools]}" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [Theme]}" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding ThemeOptions}"
                                SelectedItem="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [Language]}" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding LanguageOptions}"
                                SelectedItem="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [SidToXm]}" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding SidXmExportModes}"
                                SelectedItem="{Binding SidXmExportMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <UniformGrid Columns="2">
                      <Button Content="{Binding [SaveConfig], StringFormat=▣ {0}}" Command="{Binding SaveConfigurationCommand}" Margin="0,0,6,0"/>
                      <Button Content="{Binding [ShowHelpAction], StringFormat=i {0}}" Command="{Binding ShowAboutCommand}" Margin="6,0,0,0"/>
                    </UniformGrid>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}" Padding="16">
                  <StackPanel>
                    <TextBlock Text="{Binding [ProfessionalNotes]}" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="{Binding [ProfessionalNotesBody]}" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </ScrollViewer>
        </TabItem>

        <TabItem x:Name="SongEditorTab" Header="{Binding [TabSongEditor]}" Tag="▦">
          <song:SongEditorControl DataContext="{Binding SongEditor}"/>
        </TabItem>

        <TabItem x:Name="ChannelRackTab" Header="{Binding [TabChannelRack]}" Tag="▤">
          <channelRack:ChannelRackControl DataContext="{Binding ChannelRack}"/>
        </TabItem>

        <TabItem x:Name="AutomationTab" Header="{Binding [TabAutomation]}" Tag="⌁">
          <automation:AutomationEditorControl DataContext="{Binding Automation}"/>
        </TabItem>

        <TabItem x:Name="MixerTab" Header="{Binding [TabMixer]}" Tag="▥">
          <Grid Background="{DynamicResource BgDeep}">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Margin="12,10,12,8" Padding="12"
                    Style="{StaticResource FlMixerStrip}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="160"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="520"/>
                  <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding [Master]}" Grid.Column="0"
                           Foreground="{DynamicResource TextPrimary}"
                           FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                  <Slider Minimum="0" Maximum="1"
                          PreviewMouseLeftButtonDown="MixerSlider_PreviewMouseLeftButtonDown"
                          PreviewMouseLeftButtonUp="MixerSlider_PreviewMouseLeftButtonUp"
                          Value="{Binding MasterVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Center"/>
                  <ProgressBar Minimum="0" Maximum="1" Height="5" Margin="0,6,0,0"
                               Foreground="#59D98E"
                               Value="{Binding MasterMeterLevel, Mode=OneWay}"/>
                </StackPanel>
