                                 Foreground="{DynamicResource AccentLight}" FontFamily="Consolas"/>
                      <Slider Minimum="2" Maximum="8" TickFrequency="1" IsSnapToTickEnabled="True"
                              Value="{Binding AudioBufferCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="{Binding [TipBuffers]}"/>
                    </DockPanel>
                    <DockPanel>
                      <Button DockPanel.Dock="Right" Content="{Binding [Apply]}" Width="96" Margin="8,0,0,0"
                              Command="{Binding ApplyAudioSettingsCommand}"/>
                      <Button DockPanel.Dock="Right" Content="{Binding [Refresh]}" Width="96"
                              Command="{Binding RefreshAudioDevicesCommand}"/>
                    </DockPanel>
                  </StackPanel>
                </Border>
              </StackPanel>

              <StackPanel Grid.Column="2">
                <Border Style="{StaticResource SettingsPanel}">
                  <StackPanel>
                    <TextBlock Text="Audio devices / mixer advanced" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Priority" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1" ItemsSource="{Binding AudioPriorityOptions}"
                                SelectedItem="{Binding AudioPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Resampling quality" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1" ItemsSource="{Binding AudioResamplingQualityOptions}"
                                SelectedItem="{Binding AudioResamplingQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Playback tracking" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1" ItemsSource="{Binding AudioPlaybackTrackingOptions}"
                                SelectedItem="{Binding AudioPlaybackTracking, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <CheckBox Content="Auto-close idle audio device" IsChecked="{Binding AudioAutoClose, Mode=TwoWay}"/>
                    <CheckBox Content="Safe overload protection" IsChecked="{Binding AudioSafeOverloads, Mode=TwoWay}"/>
                    <CheckBox Content="Reset generators on transport" IsChecked="{Binding AudioResetPluginsOnTransport, Mode=TwoWay}"/>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}">
                  <StackPanel>
                    <TextBlock Text="Files, backups and tracker tools" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Autosave" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1" ItemsSource="{Binding AutosaveModeOptions}"
                                SelectedItem="{Binding FileAutosaveMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Backup location" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1" ItemsSource="{Binding BackupLocationOptions}"
                                SelectedItem="{Binding FileBackupLocationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="User data folder" Style="{StaticResource SettingLabel}"/>
                      <TextBox Grid.Column="1" Text="{Binding UserDataFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <TextBlock Text="Chiptune library folders" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold"/>
                    <ListBox ItemsSource="{Binding BrowserSearchFolders}" MinHeight="70" MaxHeight="110" Margin="0,4,0,8"/>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="External tracker tool" Style="{StaticResource SettingLabel}"/>
                      <TextBox Grid.Column="1" Text="{Binding ExternalToolPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}">
                  <StackPanel>
                    <TextBlock Text="Theme engine" Style="{StaticResource SectionTitle}"/>
                    <UniformGrid Columns="2">
                      <Grid Margin="0,0,8,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="110"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GUI scaling" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ScalingModeOptions}" SelectedItem="{Binding ThemeGuiScaling, Mode=TwoWay}"/>
                      </Grid>
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="110"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pop-ups" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ScalingModeOptions}" SelectedItem="{Binding ThemePopupScaling, Mode=TwoWay}"/>
                      </Grid>
                      <Grid Margin="0,0,8,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="110"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Toolbars" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ScalingModeOptions}" SelectedItem="{Binding ThemeToolbarScaling, Mode=TwoWay}"/>
                      </Grid>
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="110"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Color map" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ThemeColorMapOptions}" SelectedItem="{Binding ThemeColorMap, Mode=TwoWay}"/>
                      </Grid>
                    </UniformGrid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Animations" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1" ItemsSource="{Binding AnimationModeOptions}"
                                SelectedItem="{Binding ThemeAnimationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <CheckBox Content="Transparent windows" IsChecked="{Binding ThemeTransparentWindows, Mode=TwoWay}"/>
                    <CheckBox Content="High visibility editor lines" IsChecked="{Binding ThemeHighVisibility, Mode=TwoWay}"/>
                    <CheckBox Content="Small scrollbars in editors" IsChecked="{Binding ThemeSmallScrollbars, Mode=TwoWay}"/>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}">
                  <StackPanel>
                    <TextBlock Text="Project defaults" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Default template" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1" ItemsSource="{Binding ProjectTemplateOptions}"
                                SelectedItem="{Binding ProjectDefaultTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Startup project" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1" ItemsSource="{Binding StartupProjectOptions}"
                                SelectedItem="{Binding ProjectStartupProject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <CheckBox Content="Auto-name channels" IsChecked="{Binding ProjectAutoNameChannels, Mode=TwoWay}"/>
                    <CheckBox Content="Auto-select linked modules" IsChecked="{Binding ProjectAutoSelectLinkedModules, Mode=TwoWay}"/>
                    <CheckBox Content="Auto-zoom piano roll to active notes" IsChecked="{Binding ProjectAutoZoomPianoRoll, Mode=TwoWay}"/>
                    <CheckBox Content="Create automation clips at playback position" IsChecked="{Binding ProjectCreateAutomationAtPlaybackPosition, Mode=TwoWay}"/>
                    <CheckBox Content="Select first channel with notes on pattern change" IsChecked="{Binding ProjectSelectFirstNoteChannel, Mode=TwoWay}"/>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}">
                  <StackPanel>
                    <TextBlock Text="{Binding [TabPianoRoll]}" Style="{StaticResource SectionTitle}"/>
                    <CheckBox Content="{Binding [SoloPianoRoll]}"
                              IsChecked="{Binding SoloSelectedPianoRollChannel, Mode=TwoWay}"
                              ToolTip="{Binding [TipSoloPianoRoll]}"/>
                    <CheckBox Content="{Binding [AutoOpenPianoRoll]}"
                              IsChecked="{Binding AutoOpenPianoRollOnClipSelect, Mode=TwoWay}"
                              ToolTip="{Binding [TipAutoOpenPianoRoll]}"/>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [PreviewNotes]}" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding NotePreviewModes}"
                                SelectedItem="{Binding NotePreviewMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{Binding [TipPreviewNotes]}"/>
                    </Grid>
                    <CheckBox Margin="0,8,0,0"
                              Content="{Binding [TypingKeyboard]}"
                              IsChecked="{Binding PianoRollTypingKeyboardEnabled, Mode=TwoWay}"
                              ToolTip="{Binding [TipTypingKeyboard]}"/>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [KeyboardBase]}" Style="{StaticResource SettingLabel}"/>
                      <DockPanel Grid.Column="1">
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding PianoRollTypingKeyboardBaseNote}"
                                   Foreground="{DynamicResource AccentLight}" FontFamily="Consolas"/>
                        <Slider Minimum="24" Maximum="72" TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="{Binding PianoRollTypingKeyboardBaseNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{Binding [TipKeyboardBase]}"/>
                      </DockPanel>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [KeyboardVelocity]}" Style="{StaticResource SettingLabel}"/>
                      <DockPanel Grid.Column="1">
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding PianoRollTypingKeyboardVelocity}"
                                   Foreground="{DynamicResource AccentLight}" FontFamily="Consolas"/>
                        <Slider Minimum="1" Maximum="127" TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="{Binding PianoRollTypingKeyboardVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{Binding [TipKeyboardVelocity]}"/>
                      </DockPanel>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [MidiPatternDefault]}" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding MidiExportPatternDefaults}"
                                SelectedItem="{Binding MidiExportPatternDefault, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{Binding [TipMidiPatternDefault]}"/>
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}">
                  <StackPanel>
                    <TextBlock Text="{Binding [MixerVisualizer]}" Style="{StaticResource SectionTitle}"/>
                    <CheckBox Content="{Binding [DetailedMixerReadouts]}"
                              IsChecked="{Binding ShowAdvancedMixerReadouts, Mode=TwoWay}"
                              ToolTip="{Binding [TipMixerReadouts]}"/>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [AnalyzerMode]}" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding SpectrumAnalyzerModes}"
                                SelectedItem="{Binding SpectrumAnalyzerMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{Binding [TipAnalyzerMode]}"/>
                    </Grid>
                    <DockPanel Margin="0,0,0,8">
                      <TextBlock Text="{Binding [Intensity]}" Style="{StaticResource SettingLabel}" Width="150"/>
                      <TextBlock DockPanel.Dock="Right"
                                 Text="{Binding VisualizerIntensity, StringFormat={}{0:0.00}x}"
                                 Foreground="{DynamicResource AccentLight}" FontFamily="Consolas"/>
                      <Slider Minimum="0.25" Maximum="2.5"
                              Value="{Binding VisualizerIntensity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="{Binding [TipVisualizerIntensity]}"/>
                    </DockPanel>
                    <DockPanel>
                      <TextBlock Text="{Binding [PeakHold]}" Style="{StaticResource SettingLabel}" Width="150"/>
                      <TextBlock DockPanel.Dock="Right"
                                 Text="{Binding VisualizerPeakHold, StringFormat={}{0:0.000}}"
                                 Foreground="{DynamicResource AccentLight}" FontFamily="Consolas"/>
                      <Slider Minimum="0.70" Maximum="0.995"
                              Value="{Binding VisualizerPeakHold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="{Binding [TipPeakHold]}"/>
                    </DockPanel>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}">
                  <StackPanel>
                    <TextBlock Text="{Binding [ModuleSupport]}" Style="{StaticResource SectionTitle}"/>
                    <CheckBox Content="{Binding [ModuleDiagnostics]}"
                              IsChecked="{Binding ShowModuleDiagnostics, Mode=TwoWay}"
                              ToolTip="{Binding [TipModuleDiagnostics]}"/>
                    <CheckBox Content="{Binding [WarnNativeExport]}"
                              IsChecked="{Binding ConfirmNativeExportLimitations, Mode=TwoWay}"
                              ToolTip="{Binding [TipNativeExportWarn]}"/>
                    <CheckBox Content="{Binding [UseSongLengthDb]}"
                              IsChecked="{Binding PreferSongLengthDatabase, Mode=TwoWay}"
                              ToolTip="{Binding [TipSongLengthDb]}"/>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [SidToXm]}" Style="{StaticResource SettingLabel}"/>
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding SidXmExportModes}"
                                SelectedItem="{Binding SidXmExportMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{Binding [TipSidToXm]}"/>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="64"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [ChipRenderTail]}" Style="{StaticResource SettingLabel}"/>
                      <Slider Grid.Column="1" Minimum="0" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True"
                              Value="{Binding ChipRenderTailSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="{Binding [TipChipTail]}"/>
                      <TextBlock Grid.Column="2"
                                 Text="{Binding ChipRenderTailSeconds, StringFormat={}{0}s}"
                                 Foreground="{DynamicResource AccentLight}" FontFamily="Consolas"
                                 HorizontalAlignment="Right"/>
                    </Grid>
                    <TextBlock Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                               Visibility="{Binding ShowModuleDiagnostics, Converter={StaticResource BoolToVisibility}}"
                               Text="{Binding [ModuleSupportNote]}"/>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}">
                  <StackPanel>
                    <TextBlock Text="{Binding [Configuration]}" Style="{StaticResource SectionTitle}"/>
                    <UniformGrid Columns="2">
                      <Button Content="{Binding [SaveConfig], StringFormat=▣ {0}}" Margin="0,0,6,6"
                              Command="{Binding SaveConfigurationCommand}"
                              ToolTip="{Binding [TipSaveConfig]}"/>
                      <Button Content="{Binding [LoadConfig], StringFormat=⌕ {0}}" Margin="0,0,0,6"
                              Command="{Binding LoadConfigurationCommand}"
                              ToolTip="{Binding [TipLoadConfig]}"/>
                      <Button Content="{Binding [ExportConfig], StringFormat=⇱ {0}}" Margin="0,0,6,6"
                              Command="{Binding ExportConfigurationCommand}"
                              ToolTip="{Binding [TipExportConfig]}"/>
                      <Button Content="{Binding [ImportConfig], StringFormat=⇲ {0}}" Margin="0,0,0,6"
                              Command="{Binding ImportConfigurationCommand}"
                              ToolTip="{Binding [TipImportConfig]}"/>
                    </UniformGrid>
                    <Button Content="{Binding [ResetDefaults], StringFormat=↺ {0}}"
                            Command="{Binding ResetConfigurationCommand}"
                            ToolTip="{Binding [TipResetDefaults]}"/>
                    <Button Content="{Binding [RegisterOpenWith], StringFormat=↗ {0}}"
                            Command="{Binding RegisterOpenWithCommand}"
                            Margin="0,6,0,0"
                            ToolTip="{Binding [TipRegisterOpenWith]}"/>
                    <CheckBox Content="{Binding [ShowTipsStartup]}"
                              IsChecked="{Binding ShowTipsOnStartup, Mode=TwoWay}"
                              ToolTip="{Binding [TipShowStartup]}"/>
                    <CheckBox Content="{Binding [AutoSaveConfig]}"
                              IsChecked="{Binding AutoSaveConfigurationOnExit, Mode=TwoWay}"
                              ToolTip="{Binding [TipAutoSaveConfig]}"/>
                    <DockPanel Margin="0,8,0,0">
                      <TextBlock Text="{Binding [HelpTextScale]}" Style="{StaticResource SettingLabel}" Width="150"/>
                      <TextBlock DockPanel.Dock="Right"
                                 Text="{Binding HelpTextScale, StringFormat={}{0:0.00}x}"
                                 Foreground="{DynamicResource AccentLight}" FontFamily="Consolas"/>
                      <Slider Minimum="0.8" Maximum="1.6"
                              Value="{Binding HelpTextScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                    <TextBlock Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Text="{Binding [ConfigurationNote]}"/>
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsPanel}">
                  <StackPanel>
                    <TextBlock Text="{Binding [Diagnostics]}" Style="{StaticResource SectionTitle}"/>
                    <CheckBox Content="{Binding [VerboseLogging]}"
                              IsChecked="{Binding VerboseLogging, Mode=TwoWay}"
                              ToolTip="{Binding [TipVerboseLogging]}"/>
                    <CheckBox Content="{Binding [DependencyLogging]}"
                              IsChecked="{Binding LogDependencyLoadDetails, Mode=TwoWay}"
                              ToolTip="{Binding [TipDependencyLogging]}"/>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding [LogDirectory]}" Style="{StaticResource SettingLabel}"/>
                      <TextBox Grid.Column="1"
                               Text="{Binding LogDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               ToolTip="{Binding [TipLogDirectory]}"/>
                    </Grid>
                    <DockPanel Margin="0,8,0,0">
                      <Button DockPanel.Dock="Right" Content="{Binding [OpenFolder]}" Width="96" Margin="8,0,0,0"
                              Command="{Binding OpenLogFolderCommand}"/>
                      <Button DockPanel.Dock="Right" Content="{Binding [ApplyLogging]}" Width="108"
                              Command="{Binding ApplyLogSettingsCommand}"/>
                    </DockPanel>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </ScrollViewer>
        </TabItem>

      </TabControl>
    </Grid>

  </DockPanel>
</Window>
