<UserControl x:Class="amChipper.App.Controls.SongEditor.SongEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:amChipper.App.Controls.Automation"
             xmlns:local="clr-namespace:amChipper.App.Controls.SongEditor"
             Background="{DynamicResource BgPanel}">

  <UserControl.InputBindings>
    <KeyBinding Key="D" Modifiers="Control" Command="{Binding DuplicateBlockCommand}"/>
  </UserControl.InputBindings>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="42"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="220"/>
    </Grid.RowDefinitions>

    <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
    <Border Grid.Row="0" Background="{DynamicResource BgControl}"
            BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
      <DockPanel Margin="6,0">
      <Border DockPanel.Dock="Right" Width="210" Height="31" Padding="6,3"
              Background="#AA101018" BorderBrush="{DynamicResource Border}" BorderThickness="1"
              VerticalAlignment="Center"
              MouseLeftButtonUp="SpectrumPreview_MouseLeftButtonUp"
              ToolTip="{Binding DataContext[TipAnalyzerMode], RelativeSource={RelativeSource AncestorType=Window}}">
        <DockPanel>
          <TextBlock Text="{Binding DataContext[Spectrum], RelativeSource={RelativeSource AncestorType=Window}, StringFormat=▥ {0}}" DockPanel.Dock="Left"
                     Foreground="{DynamicResource TextSecondary}" FontSize="9"
                     FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <ItemsControl ItemsSource="{Binding DataContext.SpectrumBands, RelativeSource={RelativeSource AncestorType=Window}}"
                        VerticalAlignment="Bottom" HorizontalAlignment="Right">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Canvas Width="5" Height="22" Margin="1,0" VerticalAlignment="Bottom">
                  <Border Canvas.Bottom="0" Width="5" Height="{Binding CompactBarHeight}" CornerRadius="2"
                          Background="{Binding BarBrush}"/>
                  <Border Canvas.Bottom="{Binding CompactPeakHeight}" Width="5" Height="1" Background="#F1F6FF"/>
                </Canvas>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </Border>

      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

        <ToggleButton Content="{Binding DataContext[Draw], RelativeSource={RelativeSource AncestorType=Window}, StringFormat=✏ {0}}"   IsChecked="True"  x:Name="BtnDraw"   Click="Tool_Draw"   Margin="2,0"/>
        <ToggleButton Content="{Binding DataContext[Select], RelativeSource={RelativeSource AncestorType=Window}, StringFormat=⬚ {0}}" IsChecked="False" x:Name="BtnSelect" Click="Tool_Select" Margin="2,0"/>
        <ToggleButton Content="{Binding DataContext[Erase], RelativeSource={RelativeSource AncestorType=Window}, StringFormat=✕ {0}}"  IsChecked="False" x:Name="BtnErase"  Click="Tool_Erase"  Margin="2,0"/>
        <Separator Margin="8,4"/>

        <Button Content="−"
                Width="{Binding DataContext.EditorToolButtonWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                Height="{Binding DataContext.EditorToolButtonHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                FontSize="{Binding DataContext.EditorToolButtonFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                Click="ZoomOut" ToolTip="{Binding DataContext[TipZoomOut], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <TextBlock Text="{Binding DataContext[Zoom], RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center" Margin="4,0"/>
        <Button Content="+"
                Width="{Binding DataContext.EditorToolButtonWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                Height="{Binding DataContext.EditorToolButtonHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                FontSize="{Binding DataContext.EditorToolButtonFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                Click="ZoomIn"  ToolTip="{Binding DataContext[TipZoomIn], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <Button Content="100" MinWidth="34" Height="{Binding DataContext.EditorToolButtonHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                Margin="4,0,0,0" Click="ZoomReset" ToolTip="{Binding DataContext[TipZoomReset], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <Button Content="{Binding DataContext[Fit], RelativeSource={RelativeSource AncestorType=Window}}" MinWidth="34" Height="{Binding DataContext.EditorToolButtonHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                Margin="4,0,0,0" Click="ZoomFit" ToolTip="{Binding DataContext[TipZoomFit], RelativeSource={RelativeSource AncestorType=Window}}"/>

        <Separator Margin="8,4"/>
        <TextBlock Text="{Binding DataContext[Pattern], RelativeSource={RelativeSource AncestorType=Window}, StringFormat={}{0}:}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Margin="0,0,4,0"/>
        <ComboBox x:Name="CmbPattern" Width="120" VerticalAlignment="Center"
                  DisplayMemberPath="Name"
                  ItemsSource="{Binding Patterns}"
                  SelectedIndex="{Binding SelectedPatternIndex, Mode=TwoWay}"/>
        <Button Content="{Binding DataContext[DuplicateShort], RelativeSource={RelativeSource AncestorType=Window}, StringFormat=⧉ {0}}" Margin="6,0,0,0" Command="{Binding DuplicateBlockCommand}" ToolTip="{Binding DataContext[TipDuplicateBlock], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <Separator Margin="8,4"/>
        <TextBlock Text="{Binding DataContext[Clip], RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Margin="0,0,4,0"/>
        <TextBlock Text="{Binding DataContext[VolumeShort], RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Margin="0,0,4,0"/>
        <Slider x:Name="ClipVolSlider" Width="96" Minimum="0" Maximum="128"
                IsEnabled="{Binding HasSelectedBlock}"
                PreviewMouseLeftButtonDown="ClipSlider_PreviewMouseLeftButtonDown"
                PreviewMouseLeftButtonUp="ClipSlider_PreviewMouseLeftButtonUp"
                Value="{Binding BlockVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{Binding DataContext[Pan], RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Margin="10,0,4,0"/>
        <Slider x:Name="ClipPanSlider" Width="96" Minimum="0" Maximum="255"
                IsEnabled="{Binding HasSelectedBlock}"
                PreviewMouseLeftButtonDown="ClipSlider_PreviewMouseLeftButtonDown"
                PreviewMouseLeftButtonUp="ClipSlider_PreviewMouseLeftButtonUp"
                Value="{Binding BlockPan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      </StackPanel>
      </DockPanel>
    </Border>

    <!-- ── Main split: track header + timeline ──────────────────────────────── -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="160" MinWidth="100" MaxWidth="260"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Track headers -->
      <Border Background="{DynamicResource BgControl}"
              BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
        <local:TrackHeaderPanel x:Name="TrackHeaders"/>
      </Border>

      <!-- Timeline canvas + scrollbar -->
      <ScrollViewer Grid.Column="1" x:Name="TimelineScroll"
                    HorizontalScrollBarVisibility="Visible"
                    VerticalScrollBarVisibility="Auto"
                    PreviewMouseWheel="TimelineScroll_PreviewMouseWheel"
                    ScrollChanged="TimelineScroll_Changed">
        <local:TimelineCanvas x:Name="Timeline"
                              MinWidth="3000"/>
        </ScrollViewer>
      </Grid>

      <Border Grid.Row="2"
              Background="{DynamicResource BgPanel}"
              BorderBrush="{DynamicResource Border}"
              BorderThickness="0,1,0,0">
        <automation:ClipEnvelopeControl DataContext="{Binding ClipEnvelope}"/>
      </Border>
  </Grid>
</UserControl>
