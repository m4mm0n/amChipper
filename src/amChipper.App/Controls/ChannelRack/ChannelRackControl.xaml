<UserControl x:Class="amChipper.App.Controls.ChannelRack.ChannelRackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgPanel}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="32"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{DynamicResource BgControl}"
            BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
      <DockPanel Margin="8,0">
        <TextBlock Text="{Binding DataContext[TabChannelRack], RelativeSource={RelativeSource AncestorType=Window}, StringFormat=▦ {0}}" DockPanel.Dock="Left"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextSecondary}"
                   FontWeight="SemiBold"/>
        <TextBlock Text="{Binding PatternLabel}" DockPanel.Dock="Right"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource AccentLight}"
                   FontFamily="Consolas"/>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Tracks}" Margin="10,8,10,12">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    Background="{DynamicResource BgControl}" Margin="0,0,0,7" Padding="9">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="34"/>
                  <ColumnDefinition Width="245"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="24" Height="44" VerticalAlignment="Center"
                        Background="{DynamicResource BgSelect}" BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                  <TextBlock Text="{Binding TrackIndex}" HorizontalAlignment="Center"
                             VerticalAlignment="Center" FontFamily="Consolas"
                             Foreground="{DynamicResource AccentLight}"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding TrackName}" Foreground="{DynamicResource TextPrimary}"
                             FontWeight="SemiBold" Margin="0,0,0,3"/>
                  <DockPanel LastChildFill="False">
                    <TextBlock Text="{Binding PitchLabel}" Foreground="{DynamicResource TextSecondary}"
                               FontFamily="Consolas" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding InstrumentLabel}" Foreground="{DynamicResource TextSecondary}"
                               FontFamily="Consolas"/>
                  </DockPanel>
                  <TextBlock Text="{Binding EffectSummary}" Foreground="{DynamicResource AccentLight}"
                             FontFamily="Consolas" FontSize="11"
                             Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                  <ProgressBar Minimum="0" Maximum="1" Height="4" Margin="0,6,0,0"
                               Value="{Binding Track.MeterLevel, Mode=OneWay}"
                               Foreground="{DynamicResource AccentLight}" Background="{DynamicResource BgDeep}"/>
                </StackPanel>

                <ItemsControl Grid.Column="2" ItemsSource="{Binding Steps}" VerticalAlignment="Center">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <UniformGrid Columns="16"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <ToggleButton IsChecked="{Binding IsOn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="2,0"
                                    Height="34"
                                    Background="{DynamicResource BgPanel}"
                                    Foreground="{DynamicResource TextPrimary}"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="1"
                                    Content="{Binding StepIndex, StringFormat={}{0}}"
                                    FontFamily="Consolas"
                                    FontSize="11">
                        <ToggleButton.Style>
                          <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
                            <Setter Property="Template">
                              <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                  <Border x:Name="Root"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                    <Grid>
                                      <Rectangle Height="3" VerticalAlignment="Bottom"
                                                 Fill="{DynamicResource BgSelect}" Opacity="0.75"/>
                                      <ContentPresenter HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </Grid>
                                  </Border>
                                  <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                      <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentLight}"/>
                                    </Trigger>
                                  </ControlTemplate.Triggers>
                                </ControlTemplate>
                              </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                              <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentLight}"/>
                              </Trigger>
                              <DataTrigger Binding="{Binding IsCurrentStep}" Value="True">
                                <Setter Property="BorderBrush" Value="#F7D774"/>
                                <Setter Property="BorderThickness" Value="2"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </ToggleButton.Style>
                      </ToggleButton>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
